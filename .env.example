# ========================
# Конфигурация Telegram бота "Счетчик кальянов"
# ========================

# Токен Telegram бота
# Как получить: напишите /newbot в Telegram боту @BotFather
# Копируйте токен формата: 123456789:ABCdefGHIjklmnoPQRstuvWXYZabcdefg
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_USER_ID=YOUR_TELEGRAM_ID_HERE
REPORT_CHAT_ID=YOUR_TELEGRAM_GROUP_ID_HERE

# Путь к базе данных (опционально, по умолчанию hookah_bot.db в корне)
# DB_PATH=hookah_bot.db

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ========================
# Конфигурация Instagram парсера
# ========================

# Учетные данные Instagram аккаунта для парсинга
# ВАЖНО: используйте ОТДЕЛЬНЫЙ аккаунт, не основной!
# Instagram может заблокировать аккаунт за частые запросы
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Аккаунт для парсинга (имя профиля без @)
# Пример: mount.bar
INSTAGRAM_ACCOUNT=mount.bar

# ID Telegram чата для отправки постов/историй из Instagram
# Пример группового чата: -1003826622440
TARGET_CHAT_ID=-1003826622440

# ===== Gmail (для автоматического чтения кода верификации) =====
# Рекомендуется использовать App Password (если у вас включена 2FA) или OAuth
# Как создать App Password: https://support.google.com/accounts/answer/185833
GMAIL_EMAIL=your.email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Интервал проверки Instagram в секундах (по умолчанию 10)
INSTAGRAM_POLL_INTERVAL=300